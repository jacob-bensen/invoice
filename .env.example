DATABASE_URL=postgres://user:password@localhost:5432/decentinvoice
SESSION_SECRET=change-this-to-a-long-random-string
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...           # monthly Pro subscription price ($12/mo)
STRIPE_PRO_ANNUAL_PRICE_ID=price_...    # annual Pro subscription price ($99/yr)
APP_URL=https://your-app.herokuapp.com
NODE_ENV=production
PORT=3000

# Resend transactional email (https://resend.com/api-keys).
# When unset, lib/email.js degrades gracefully: send calls become no-ops and
# Pro-feature email sending is skipped — the rest of the app keeps working.
RESEND_API_KEY=re_...
EMAIL_FROM="DecentInvoice <invoices@decentinvoice.com>"

# Stripe Tax: when enabled, Stripe auto-calculates VAT/GST/sales tax for
# EU/UK/AU/CA customers based on their billing address. Set to "true" only
# AFTER activating Stripe Tax in the Stripe Dashboard (Settings → Tax →
# Activate). Until then, leave as "false" — checkout still works, just
# without tax collection.
STRIPE_AUTOMATIC_TAX_ENABLED=false

# Stripe Payment Link payment methods. Comma-separated list of methods that
# clients can use to pay an invoice via the auto-generated Stripe Payment
# Link. Defaults to card-only. Lower-fee bank-debit methods (us_bank_account
# = ACH @ 0.8% capped $5, sepa_debit = EU @ 0.8% capped €5, au_becs_debit =
# AU) save the freelancer significant fees on $300+ invoices. Each method
# must first be enabled in the Stripe Dashboard (Settings → Payments →
# Payment methods). Allowed values: card, us_bank_account, sepa_debit,
# au_becs_debit, bacs_debit, acss_debit, link. Unknown values are ignored.
# Example: STRIPE_PAYMENT_METHODS=card,us_bank_account,sepa_debit
STRIPE_PAYMENT_METHODS=card

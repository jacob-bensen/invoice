<!-- Free-plan invoice-limit upgrade modal -->
<!-- Trigger: add ?limit_hit=1 to the URL on any page that includes this partial. -->
<div
  x-data="upgradeModal()"
  x-init="init()"
  x-show="open"
  x-cloak
  @keydown.escape.window="close()"
  class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/70 px-4"
  style="display:none"
>
  <div
    @click.outside="close()"
    x-transition:enter="transition ease-out duration-150"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
    class="bg-white rounded-2xl shadow-2xl max-w-lg w-full overflow-hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="upgrade-modal-title"
  >
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 px-8 py-8 text-white relative">
      <button
        type="button"
        @click="close()"
        class="absolute top-4 right-4 text-white/70 hover:text-white text-2xl leading-none"
        aria-label="Close"
      >&times;</button>
      <div class="text-4xl mb-3">🚀</div>
      <h2 id="upgrade-modal-title" class="text-2xl font-bold mb-2">You've hit the free plan limit</h2>
      <p class="text-brand-100 text-sm">
        You've created 3 invoices on the Free plan. Upgrade to Pro to keep invoicing without limits.
      </p>
    </div>

    <div class="px-8 py-6">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Everything in Pro</p>
      <ul class="space-y-2.5 text-sm text-gray-700 mb-6">
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span><strong>Unlimited invoices</strong> — never hit a cap again</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Email invoices directly to clients</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Stripe payment links on every invoice</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Custom branding: your logo, your colors</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Priority support — cancel anytime</span>
        </li>
      </ul>

      <!-- Billing-cycle selector (Monthly / Annual) -->
      <div class="flex items-center justify-center gap-2 mb-2">
        <button
          type="button"
          @click="cycle = 'monthly'"
          :class="cycle === 'monthly' ? 'bg-brand-50 text-brand-700 border-brand-200' : 'bg-white text-gray-500 border-gray-200'"
          class="px-3 py-1.5 rounded-lg text-xs font-semibold transition border"
        >Monthly — $12/mo</button>
        <button
          type="button"
          @click="cycle = 'annual'"
          :class="cycle === 'annual' ? 'bg-brand-50 text-brand-700 border-brand-200' : 'bg-white text-gray-500 border-gray-200'"
          class="px-3 py-1.5 rounded-lg text-xs font-semibold transition border flex items-center gap-1.5"
        >
          Annual — $99/yr
          <span class="bg-green-100 text-green-700 text-[10px] font-bold px-1.5 py-0.5 rounded">Save 31%</span>
        </button>
      </div>
      <p class="text-center text-xs font-semibold mb-4" x-show="cycle === 'annual'" x-cloak>
        <span class="inline-flex items-center gap-1.5 bg-green-100 text-green-700 px-2.5 py-1 rounded-full">
          <span aria-hidden="true">💰</span>
          Save $45/year vs. paying monthly
        </span>
      </p>
      <p class="text-center text-xs mb-4" x-show="cycle === 'monthly'">&nbsp;</p>

      <form action="/billing/create-checkout" method="POST" class="mb-3">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <input type="hidden" name="billing_cycle" :value="cycle">
        <button
          type="submit"
          class="w-full bg-brand-600 text-white font-bold py-3 rounded-xl hover:bg-brand-700 transition text-center"
        >
          Start 7-day free trial &rarr;
        </button>
      </form>

      <p class="text-center text-xs text-gray-400 mb-4">
        No credit card required. Cancel anytime.<br>
        After trial: <span x-show="cycle === 'monthly'">$12/month</span><span x-show="cycle === 'annual'" x-cloak>$99/year</span> · Secure checkout via Stripe
      </p>

      <div class="flex items-center justify-center gap-4 text-xs">
        <a href="/billing/upgrade" class="text-gray-500 hover:text-gray-700 underline underline-offset-2">
          See full pricing
        </a>
        <span class="text-gray-300">·</span>
        <button
          type="button"
          @click="close()"
          class="text-gray-500 hover:text-gray-700"
        >
          Not now
        </button>
      </div>

      <!--
        #145 — "What's missing?" feedback widget. The silent close-without-
        upgrade signal is the most common, least-actionable outcome on this
        modal. The <details> disclosure stays out of the way for users who
        intend to upgrade and is the one path a hesitant user can take to
        tell us *why* they didn't. Submission POSTs JSON to /billing/feedback
        which writes feedback_signals; UI flips to a "thanks" state without
        closing the modal so the user can still upgrade afterwards.
      -->
      <details class="mt-5 border-t border-gray-100 pt-4 text-xs" data-feedback-widget>
        <summary class="cursor-pointer text-gray-500 hover:text-gray-700 font-medium select-none list-none flex items-center gap-1">
          <span aria-hidden="true">💬</span>
          <span>Not upgrading? Tell us what's missing</span>
        </summary>
        <form
          x-data="upgradeFeedback()"
          @submit.prevent="submit()"
          class="mt-3 space-y-3"
          data-testid="upgrade-feedback-form"
        >
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
          <input type="hidden" name="source" value="upgrade-modal">
          <div class="space-y-1.5">
            <label class="flex items-start gap-2 text-gray-600">
              <input type="radio" name="reason" value="too_expensive" x-model="reason" class="mt-0.5">
              <span>Too expensive for me right now</span>
            </label>
            <label class="flex items-start gap-2 text-gray-600">
              <input type="radio" name="reason" value="missing_feature" x-model="reason" class="mt-0.5">
              <span>Missing a feature I need</span>
            </label>
            <label class="flex items-start gap-2 text-gray-600">
              <input type="radio" name="reason" value="not_ready" x-model="reason" class="mt-0.5">
              <span>Not ready to commit yet</span>
            </label>
            <label class="flex items-start gap-2 text-gray-600">
              <input type="radio" name="reason" value="still_evaluating" x-model="reason" class="mt-0.5">
              <span>Still comparing alternatives</span>
            </label>
            <label class="flex items-start gap-2 text-gray-600">
              <input type="radio" name="reason" value="other" x-model="reason" class="mt-0.5">
              <span>Something else</span>
            </label>
          </div>
          <textarea
            name="message"
            x-model="message"
            rows="2"
            maxlength="1000"
            placeholder="Optional: which feature, which competitor, what blocks you?"
            class="w-full text-xs rounded-md border border-gray-200 px-2 py-1.5 focus:border-brand-400 focus:outline-none focus:ring-1 focus:ring-brand-200"
          ></textarea>
          <div class="flex items-center justify-between">
            <button
              type="submit"
              :disabled="submitting || (!reason && !message)"
              class="bg-gray-100 hover:bg-gray-200 disabled:opacity-40 disabled:cursor-not-allowed text-gray-700 font-medium px-3 py-1.5 rounded-md text-xs transition"
              data-testid="upgrade-feedback-submit"
            >
              <span x-show="!submitting">Send feedback</span>
              <span x-show="submitting" x-cloak>Sending…</span>
            </button>
            <span
              x-show="thanks"
              x-cloak
              class="text-emerald-600 font-medium"
              data-testid="upgrade-feedback-thanks"
            >Thanks — we read every reply.</span>
            <span
              x-show="errored"
              x-cloak
              class="text-red-500 font-medium"
              data-testid="upgrade-feedback-error"
            >Could not send. Try again?</span>
          </div>
        </form>
      </details>
    </div>
  </div>
</div>

<script>
  function upgradeFeedback() {
    return {
      reason: '',
      message: '',
      submitting: false,
      thanks: false,
      errored: false,
      async submit() {
        if (this.submitting || this.thanks) return;
        if (!this.reason && !this.message) return;
        this.submitting = true;
        this.errored = false;
        try {
          var csrfEl = document.querySelector(
            '[data-feedback-widget] input[name="_csrf"]'
          );
          var csrf = csrfEl ? csrfEl.value : '';
          var cycleEl = document.querySelector(
            '[x-data="upgradeModal()"] input[name="billing_cycle"]'
          );
          var cycle = cycleEl ? cycleEl.value : '';
          var r = await fetch('/billing/feedback', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
              'X-CSRF-Token': csrf
            },
            body: JSON.stringify({
              source: 'upgrade-modal',
              reason: this.reason || null,
              message: this.message || null,
              cycle: cycle || null
            })
          });
          if (!r.ok) throw new Error('http_' + r.status);
          this.thanks = true;
        } catch (e) {
          this.errored = true;
        } finally {
          this.submitting = false;
        }
      }
    };
  }
</script>

<script>
  function upgradeModal() {
    return {
      open: false,
      cycle: 'monthly',
      init() {
        try {
          const params = new URLSearchParams(window.location.search);
          if (params.get('limit_hit') === '1') {
            this.open = true;
            this.cleanUrl();
          }
        } catch (e) { /* noop */ }
      },
      close() {
        this.open = false;
      },
      cleanUrl() {
        try {
          const url = new URL(window.location.href);
          url.searchParams.delete('limit_hit');
          window.history.replaceState({}, '', url.toString());
        } catch (e) { /* noop */ }
      }
    };
  }
</script>

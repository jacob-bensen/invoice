<!-- Free-plan invoice-limit upgrade modal -->
<!-- Trigger: add ?limit_hit=1 to the URL on any page that includes this partial. -->
<div
  x-data="upgradeModal()"
  x-init="init()"
  x-show="open"
  x-cloak
  @keydown.escape.window="close()"
  class="fixed inset-0 z-50 flex items-center justify-center bg-gray-900/70 px-4"
  style="display:none"
>
  <div
    @click.outside="close()"
    x-transition:enter="transition ease-out duration-150"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
    class="bg-white rounded-2xl shadow-2xl max-w-lg w-full overflow-hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="upgrade-modal-title"
  >
    <div class="bg-gradient-to-br from-brand-600 to-brand-800 px-8 py-8 text-white relative">
      <button
        type="button"
        @click="close()"
        class="absolute top-4 right-4 text-white/70 hover:text-white text-2xl leading-none"
        aria-label="Close"
      >&times;</button>
      <div class="text-4xl mb-3">🚀</div>
      <h2 id="upgrade-modal-title" class="text-2xl font-bold mb-2">You've hit the free plan limit</h2>
      <p class="text-brand-100 text-sm">
        You've created 3 invoices on the Free plan. Upgrade to Pro to keep invoicing without limits.
      </p>
    </div>

    <div class="px-8 py-6">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Everything in Pro</p>
      <ul class="space-y-2.5 text-sm text-gray-700 mb-6">
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span><strong>Unlimited invoices</strong> — never hit a cap again</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Email invoices directly to clients</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Stripe payment links on every invoice</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Custom branding: your logo, your colors</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-green-500 font-bold mt-0.5">✓</span>
          <span>Priority support — cancel anytime</span>
        </li>
      </ul>

      <form action="/billing/create-checkout" method="POST" class="mb-3">
        <button
          type="submit"
          class="w-full bg-brand-600 text-white font-bold py-3 rounded-xl hover:bg-brand-700 transition text-center"
        >
          Upgrade to Pro — $12/month →
        </button>
      </form>

      <p class="text-center text-xs text-gray-400 mb-4">
        Join thousands of freelancers already on Pro · Secure checkout via Stripe
      </p>

      <div class="flex items-center justify-center gap-4 text-xs">
        <a href="/billing/upgrade" class="text-gray-500 hover:text-gray-700 underline underline-offset-2">
          See full pricing
        </a>
        <span class="text-gray-300">·</span>
        <button
          type="button"
          @click="close()"
          class="text-gray-500 hover:text-gray-700"
        >
          Not now
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function upgradeModal() {
    return {
      open: false,
      init() {
        try {
          const params = new URLSearchParams(window.location.search);
          if (params.get('limit_hit') === '1') {
            this.open = true;
            this.cleanUrl();
          }
        } catch (e) { /* noop */ }
      },
      close() {
        this.open = false;
      },
      cleanUrl() {
        try {
          const url = new URL(window.location.href);
          url.searchParams.delete('limit_hit');
          window.history.replaceState({}, '', url.toString());
        } catch (e) { /* noop */ }
      }
    };
  }
</script>

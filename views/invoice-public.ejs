<%- include('partials/head') %>

<%
  const ownerBusinessName = invoice.owner_business_name || invoice.owner_name || 'A DecentInvoice user';
  const ownerEmail = invoice.owner_business_email || invoice.owner_email || '';
  const ownerPhone = invoice.owner_business_phone || '';
  const ownerAddress = invoice.owner_business_address || '';
  const ownerIsPaid = invoice.owner_plan === 'pro' || invoice.owner_plan === 'agency';
  const statusColors = {
    draft: 'bg-gray-100 text-gray-600',
    sent: 'bg-blue-100 text-blue-700',
    paid: 'bg-green-100 text-green-700',
    overdue: 'bg-red-100 text-red-700'
  };
  const statusLabel = invoice.status.charAt(0).toUpperCase() + invoice.status.slice(1);
%>

<header class="bg-white border-b border-gray-200 px-4 py-3">
  <div class="max-w-4xl mx-auto flex items-center justify-between">
    <div class="text-sm text-gray-600">
      <span class="font-semibold text-gray-900"><%= ownerBusinessName %></span>
      <span class="text-gray-400"> sent you an invoice</span>
    </div>
    <a href="/" class="text-xs text-gray-400 hover:text-brand-600" data-testid="public-powered-by">
      ⚡ Powered by <span class="font-semibold">DecentInvoice</span>
    </a>
  </div>
</header>

<div class="max-w-4xl mx-auto px-4 py-10" data-testid="public-invoice">
  <!-- Pay-now hero (Pro/Agency owner with an attached Stripe payment link) -->
  <% if (invoice.payment_link_url && ownerIsPaid && invoice.status !== 'paid') { %>
    <div class="bg-white rounded-2xl border border-brand-200 shadow-sm p-6 mb-6 flex flex-wrap items-center gap-4" data-testid="public-pay-cta">
      <div class="flex-1 min-w-0">
        <p class="text-xs font-semibold text-brand-700 uppercase tracking-wide mb-1">Pay this invoice</p>
        <p class="text-gray-700 text-sm">
          Pay $<%= parseFloat(invoice.total).toFixed(2) %> to
          <span class="font-semibold"><%= ownerBusinessName %></span>
          securely via Stripe.
        </p>
      </div>
      <a href="<%= invoice.payment_link_url %>" target="_blank" rel="noopener"
        class="bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-brand-700 transition whitespace-nowrap">
        Pay $<%= parseFloat(invoice.total).toFixed(2) %> →
      </a>
    </div>
  <% } %>

  <% if (invoice.status === 'paid') { %>
    <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 mb-6 text-sm" data-testid="public-paid-banner">
      <span class="font-semibold">Paid.</span> Thanks — this invoice has been settled.
    </div>
  <% } %>

  <!-- Invoice card -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 md:p-12">
    <div class="flex justify-between items-start mb-10">
      <div>
        <h2 class="text-2xl font-bold text-gray-900"><%= ownerBusinessName %></h2>
        <% if (ownerAddress) { %>
          <p class="text-gray-400 text-sm mt-1 whitespace-pre-line"><%= ownerAddress %></p>
        <% } %>
        <% if (ownerEmail) { %>
          <p class="text-gray-400 text-sm"><%= ownerEmail %></p>
        <% } %>
        <% if (ownerPhone) { %>
          <p class="text-gray-400 text-sm"><%= ownerPhone %></p>
        <% } %>
      </div>
      <div class="text-right">
        <div class="text-3xl font-extrabold text-brand-600">INVOICE</div>
        <div class="text-gray-500 text-sm mt-1">#<%= invoice.invoice_number %></div>
        <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mt-2 <%= statusColors[invoice.status] || 'bg-gray-100 text-gray-600' %>">
          <%= statusLabel %>
        </span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-8 mb-10">
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Bill To</p>
        <p class="font-semibold text-gray-800"><%= invoice.client_name %></p>
        <% if (invoice.client_email) { %><p class="text-gray-500 text-sm"><%= invoice.client_email %></p><% } %>
        <% if (invoice.client_address) { %><p class="text-gray-500 text-sm whitespace-pre-line"><%= invoice.client_address %></p><% } %>
      </div>
      <div class="text-right">
        <div class="space-y-1 text-sm">
          <div class="flex justify-end gap-8">
            <span class="text-gray-400">Issue Date</span>
            <span class="font-medium text-gray-700"><%= new Date(invoice.issued_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></span>
          </div>
          <% if (invoice.due_date) { %>
          <div class="flex justify-end gap-8">
            <span class="text-gray-400">Due Date</span>
            <span class="font-medium text-gray-700"><%= new Date(invoice.due_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></span>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b-2 border-gray-200">
          <th class="text-left py-2 text-gray-500 font-semibold">Description</th>
          <th class="text-center py-2 text-gray-500 font-semibold w-20">Qty</th>
          <th class="text-right py-2 text-gray-500 font-semibold w-28">Unit Price</th>
          <th class="text-right py-2 text-gray-500 font-semibold w-28">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% (invoice.items || []).forEach(item => { %>
          <tr class="border-b border-gray-100">
            <td class="py-3 text-gray-700"><%= item.description %></td>
            <td class="py-3 text-center text-gray-500"><%= item.quantity %></td>
            <td class="py-3 text-right text-gray-500">$<%= parseFloat(item.unit_price).toFixed(2) %></td>
            <td class="py-3 text-right font-medium text-gray-800">$<%= (item.quantity * item.unit_price).toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="flex justify-end mb-8">
      <div class="w-64 space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-500">Subtotal</span>
          <span class="font-medium">$<%= parseFloat(invoice.subtotal).toFixed(2) %></span>
        </div>
        <% if (parseFloat(invoice.tax_rate) > 0) { %>
          <div class="flex justify-between">
            <span class="text-gray-500">Tax (<%= invoice.tax_rate %>%)</span>
            <span class="font-medium">$<%= parseFloat(invoice.tax_amount).toFixed(2) %></span>
          </div>
        <% } %>
        <div class="flex justify-between border-t border-gray-200 pt-2">
          <span class="font-bold text-gray-800">Total</span>
          <span class="font-bold text-xl text-gray-900">$<%= parseFloat(invoice.total).toFixed(2) %></span>
        </div>
      </div>
    </div>

    <% if (invoice.notes) { %>
      <div class="border-t border-gray-100 pt-6">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Notes</p>
        <p class="text-gray-500 text-sm whitespace-pre-line"><%= invoice.notes %></p>
      </div>
    <% } %>
  </div>

  <!-- Powered-by attribution footer (#48 hook). Surfaces DecentInvoice to
       every client who receives a Pro user's share link — a passive
       acquisition channel that compounds with every invoice sent. -->
  <p class="text-center text-xs text-gray-400 mt-8" data-testid="public-attribution">
    Sent via <a href="/" class="font-semibold text-brand-600 hover:underline">⚡ DecentInvoice</a> —
    <a href="/auth/register" class="hover:underline">send your own invoice in 60 seconds</a>.
  </p>
</div>

</body>
</html>

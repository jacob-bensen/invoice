<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="max-w-2xl mx-auto px-4 py-10">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Account Settings</h1>
  <p class="text-gray-500 text-sm mb-8">These details appear on every invoice you send. Filling them in makes your invoices look more professional and helps clients reach you.</p>

  <% if (locals.flash) { %>
    <div class="mb-6 p-3 rounded-lg text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
      <%= flash.message %>
    </div>
  <% } %>

  <div class="bg-white rounded-2xl border border-gray-200 p-8">
    <form action="/billing/settings" method="POST" class="space-y-5">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
        <input type="text" name="name" value="<%= user.name || '' %>" required
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Business Name</label>
        <input type="text" name="business_name" value="<%= user.business_name || '' %>" placeholder="Optional — leave blank to use your name"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Business Address</label>
        <textarea name="business_address" rows="3" placeholder="123 Main St&#10;City, State 12345"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"><%= user.business_address || '' %></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Business Email</label>
          <input type="email" name="business_email" value="<%= user.business_email || '' %>" placeholder="<%= user.email %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Business Phone</label>
          <input type="tel" name="business_phone" value="<%= user.business_phone || '' %>" placeholder="+1 (555) 000-0000"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Reply-to email <span class="text-gray-400 font-normal">(optional)</span></label>
        <input type="email" name="reply_to_email" value="<%= user.reply_to_email || '' %>" placeholder="<%= user.business_email || user.email %>"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        <p class="text-xs text-gray-500 mt-1">When clients reply to invoice emails, replies go here. Defaults to your business email.</p>
      </div>
      <div class="pt-2">
        <button type="submit" class="bg-brand-600 text-white font-semibold px-6 py-2.5 rounded-lg hover:bg-brand-700 transition">
          Save Settings
        </button>
      </div>
    </form>
  </div>

  <!-- Zapier / Outbound Webhook (Pro only) -->
  <div class="bg-white rounded-2xl border border-gray-200 p-8 mt-6">
    <div class="flex items-center justify-between mb-2">
      <h2 class="font-semibold text-gray-700">Zapier / Webhook</h2>
      <span class="bg-brand-100 text-brand-700 text-[10px] font-bold px-2 py-0.5 rounded-full">PRO</span>
    </div>
    <p class="text-sm text-gray-500 mb-4">
      Get notified the moment an invoice is paid. We'll POST a JSON event to your URL — paste it into a Zapier
      or Make catch-hook to trigger Slack pings, Google Sheets rows, anything.
    </p>
    <% if (user.plan === 'pro' || user.plan === 'agency') { %>
      <form action="/billing/webhook-url" method="POST" class="space-y-3">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <input type="url" name="webhook_url" value="<%= user.webhook_url || '' %>"
          placeholder="https://hooks.zapier.com/hooks/catch/..."
          pattern="https?://.+"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 font-mono">
        <div class="flex items-center gap-3">
          <button type="submit" class="bg-brand-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-brand-700 transition">
            Save webhook
          </button>
          <% if (user.webhook_url) { %>
            <span class="text-xs text-green-700">✓ Webhook configured</span>
          <% } %>
        </div>
      </form>
      <details class="mt-4 text-xs text-gray-500">
        <summary class="cursor-pointer">Payload shape</summary>
        <pre class="bg-gray-50 rounded p-3 mt-2 overflow-x-auto text-[11px]">{
  "event": "invoice.paid",
  "invoice_id": 123,
  "invoice_number": "INV-2026-0123",
  "amount": 500,
  "currency": "usd",
  "client_name": "Acme Corp",
  "client_email": "billing@acme.com",
  "paid_at": "2026-04-23T14:30:00.000Z"
}</pre>
      </details>

      <div class="mt-5 border-t border-gray-100 pt-4 space-y-2">
        <p class="text-[11px] font-semibold text-gray-400 uppercase tracking-wide">Quick start</p>
        <details class="text-xs text-gray-600">
          <summary class="cursor-pointer font-medium text-gray-700">💬 Use with Slack</summary>
          <div class="mt-2 space-y-2 pl-1">
            <ol class="list-decimal pl-4 space-y-1">
              <li>Open your Slack workspace, then go to <strong>Apps</strong> → <strong>Manage</strong> → <strong>Custom Integrations</strong> → <strong>Incoming Webhooks</strong>.</li>
              <li>Click <strong>Add to Slack</strong>, choose the channel, and copy the generated <code class="bg-gray-100 rounded px-1">https://hooks.slack.com/services/…</code> URL.</li>
              <li>Paste it above and save. Each paid invoice will post a message like <em>“💸 Invoice INV-2026-0123 paid by Acme Corp — $500.00”</em>.</li>
            </ol>
            <p class="text-gray-400 text-[11px]">No formatting setup needed — QuickInvoice detects Slack URLs and sends the right payload automatically.</p>
          </div>
        </details>
        <details class="text-xs text-gray-600">
          <summary class="cursor-pointer font-medium text-gray-700">🎮 Use with Discord</summary>
          <div class="mt-2 space-y-2 pl-1">
            <ol class="list-decimal pl-4 space-y-1">
              <li>In your Discord server, open the channel and click the gear icon → <strong>Integrations</strong> → <strong>Webhooks</strong>.</li>
              <li>Click <strong>New Webhook</strong>, name it (e.g. “Invoices”), then copy the URL — it starts with <code class="bg-gray-100 rounded px-1">https://discord.com/api/webhooks/…</code>.</li>
              <li>Paste it above and save. Paid invoices will post in the channel automatically.</li>
            </ol>
          </div>
        </details>
        <details class="text-xs text-gray-600">
          <summary class="cursor-pointer font-medium text-gray-700">⚡ Use with Zapier or Make</summary>
          <div class="mt-2 pl-1 text-gray-500">
            Use any catch-hook URL (Zapier, Make, n8n, your own server). QuickInvoice will POST the JSON shape shown above.
          </div>
        </details>
      </div>
    <% } else { %>
      <%- include('partials/pro-lock', { proLock: {
        feature: 'webhook',
        icon: '🔗',
        headline: 'Pipe every paid invoice into Slack, Zapier, or a spreadsheet',
        benefit: 'Pro fires a JSON POST the moment any invoice is marked paid — paste a Zapier or Make hook URL above and stop chasing payments in three different tabs.'
      } }) %>
    <% } %>
  </div>

  <!-- Plan info -->
  <div class="bg-white rounded-2xl border border-gray-200 p-8 mt-6" x-data="settingsPlan()">
    <h2 class="font-semibold text-gray-700 mb-4">Subscription</h2>
    <div class="flex items-center justify-between mb-5">
      <div>
        <p class="font-medium text-gray-800">
          <% if (user.plan === 'pro') { %>
            <span class="bg-brand-100 text-brand-700 text-xs font-bold px-2 py-0.5 rounded-full mr-2">PRO</span>
            Pro Plan · Active subscription
          <% } else { %>
            Free Plan · <%= user.invoice_count %>/3 invoices used
          <% } %>
        </p>
      </div>
      <% if (user.plan === 'pro') { %>
        <form action="/billing/portal" method="POST">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
          <button class="text-sm text-brand-600 hover:underline font-medium">Manage subscription</button>
        </form>
      <% } %>
    </div>

    <% if (user.plan !== 'pro') { %>
      <!-- Upgrade selector with billing-cycle toggle -->
      <div class="border-t border-gray-100 pt-5">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">Upgrade to Pro</p>
        <div class="flex items-center gap-3 mb-4">
          <button
            type="button"
            @click="cycle = 'monthly'"
            :class="cycle === 'monthly' ? 'bg-brand-50 text-brand-700 border-brand-200' : 'bg-white text-gray-500 border-gray-200 hover:text-gray-700'"
            class="px-3 py-1.5 rounded-lg text-sm font-semibold transition border"
          >Monthly — $12/mo</button>
          <button
            type="button"
            @click="cycle = 'annual'"
            :class="cycle === 'annual' ? 'bg-brand-50 text-brand-700 border-brand-200' : 'bg-white text-gray-500 border-gray-200 hover:text-gray-700'"
            class="px-3 py-1.5 rounded-lg text-sm font-semibold transition border flex items-center gap-2"
          >
            Annual — $99/yr
            <span class="bg-green-100 text-green-700 text-[10px] font-bold px-1.5 py-0.5 rounded">Save 31%</span>
          </button>
        </div>
        <p class="text-xs font-semibold mb-3" x-show="cycle === 'annual'" x-cloak>
          <span class="inline-flex items-center gap-1.5 bg-green-100 text-green-700 px-2 py-1 rounded-full">
            <span aria-hidden="true">💰</span>
            Save $45/year vs. paying monthly
          </span>
        </p>
        <form action="/billing/create-checkout" method="POST">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
          <input type="hidden" name="billing_cycle" :value="cycle">
          <button type="submit" class="bg-brand-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-brand-700 transition">
            Start 7-day free trial &rarr;
          </button>
          <p class="text-xs text-gray-500 mt-2">No credit card required. Cancel anytime.</p>
        </form>
      </div>
    <% } %>
  </div>
</div>

<script>
  function settingsPlan() {
    return { cycle: 'monthly' };
  }
</script>

<%- include('partials/footer') %>

</body>
</html>

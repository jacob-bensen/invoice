<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Invoice <%= invoice.invoice_number %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 13px; color: #1f2937; background: white; }
    .page { max-width: 780px; margin: 0 auto; padding: 48px; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 48px; }
    .business-name { font-size: 20px; font-weight: 700; color: #111827; }
    .business-info { color: #6b7280; font-size: 12px; margin-top: 6px; line-height: 1.6; }
    .invoice-title { font-size: 28px; font-weight: 900; color: #4f46e5; letter-spacing: -0.5px; }
    .invoice-meta { font-size: 12px; color: #9ca3af; margin-top: 4px; text-align: right; }
    .details { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 40px; }
    .label { font-size: 10px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
    .client-name { font-size: 15px; font-weight: 600; color: #111827; }
    .client-info { font-size: 12px; color: #6b7280; margin-top: 4px; line-height: 1.6; }
    .meta-table { font-size: 12px; line-height: 2; }
    .meta-table td:first-child { color: #9ca3af; padding-right: 24px; }
    .meta-table td:last-child { font-weight: 600; color: #374151; text-align: right; }
    table.items { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    table.items thead th { border-bottom: 2px solid #e5e7eb; padding: 10px 8px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6b7280; }
    table.items thead th:first-child { text-align: left; }
    table.items thead th:not(:first-child) { text-align: right; }
    table.items thead th:nth-child(2) { text-align: center; }
    table.items tbody td { padding: 12px 8px; border-bottom: 1px solid #f3f4f6; font-size: 13px; }
    table.items tbody td:first-child { color: #374151; }
    table.items tbody td:not(:first-child) { text-align: right; color: #6b7280; }
    table.items tbody td:nth-child(2) { text-align: center; }
    table.items tbody td:last-child { font-weight: 600; color: #111827; }
    .totals { display: flex; justify-content: flex-end; margin-bottom: 40px; }
    .totals-inner { width: 240px; }
    .totals-row { display: flex; justify-content: space-between; font-size: 13px; padding: 4px 0; }
    .totals-row span:first-child { color: #6b7280; }
    .totals-row span:last-child { font-weight: 500; }
    .totals-total { display: flex; justify-content: space-between; border-top: 2px solid #e5e7eb; padding-top: 10px; margin-top: 8px; }
    .totals-total span:first-child { font-weight: 700; font-size: 14px; color: #374151; }
    .totals-total span:last-child { font-weight: 900; font-size: 20px; color: #111827; }
    .notes { border-top: 1px solid #e5e7eb; padding-top: 24px; }
    .notes p { font-size: 12px; color: #6b7280; line-height: 1.7; white-space: pre-line; }
    .paylink { border-top: 1px solid #e5e7eb; padding-top: 24px; margin-top: 24px; display: flex; gap: 24px; align-items: center; }
    .paylink .info { flex: 1; }
    .paylink .info h3 { font-size: 14px; font-weight: 700; color: #065f46; margin-bottom: 6px; }
    .paylink .info p { font-size: 12px; color: #6b7280; line-height: 1.6; margin-bottom: 8px; }
    .paylink .info a { font-size: 11px; color: #4f46e5; word-break: break-all; text-decoration: underline; font-family: 'Menlo', 'Courier New', monospace; }
    .paylink .qr { width: 120px; height: 120px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border: 1px solid #e5e7eb; border-radius: 6px; background: white; }
    .paylink .qr svg { width: 110px; height: 110px; }
    .free-footer { margin-top: 48px; padding-top: 16px; border-top: 1px solid #f3f4f6; text-align: center; font-size: 10px; color: #9ca3af; letter-spacing: 0.02em; }
    .free-footer a { color: #9ca3af; text-decoration: none; }
    .print-actions { background: #f8fafc; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e5e7eb; }
    .print-actions button { background: #4f46e5; color: white; border: none; padding: 10px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; }
    .print-actions button:hover { background: #4338ca; }
    .print-actions .back { color: #6b7280; text-decoration: none; font-size: 14px; }
    @media print {
      .print-actions { display: none; }
      body { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    }
  </style>
</head>
<body>

<div class="print-actions">
  <a href="/invoices/<%= invoice.id %>" class="back">← Back to invoice</a>
  <button onclick="window.print()">🖨️ Print / Save as PDF</button>
</div>

<div class="page">
  <!-- Header -->
  <div class="header">
    <div>
      <div class="business-name"><%= user.business_name || user.name || 'Your Business' %></div>
      <div class="business-info">
        <% if (user.business_address) { %><%= user.business_address %><br><% } %>
        <% if (user.business_email || user.email) { %><%= user.business_email || user.email %><br><% } %>
        <% if (user.business_phone) { %><%= user.business_phone %><% } %>
      </div>
    </div>
    <div>
      <div class="invoice-title">INVOICE</div>
      <div class="invoice-meta">#<%= invoice.invoice_number %></div>
    </div>
  </div>

  <!-- Details -->
  <div class="details">
    <div>
      <div class="label">Bill To</div>
      <div class="client-name"><%= invoice.client_name %></div>
      <div class="client-info">
        <% if (invoice.client_email) { %><%= invoice.client_email %><br><% } %>
        <% if (invoice.client_address) { %><%= invoice.client_address %><% } %>
      </div>
    </div>
    <div style="text-align: right;">
      <table class="meta-table" style="margin-left: auto;">
        <tr>
          <td>Issue Date</td>
          <td><%= new Date(invoice.issued_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></td>
        </tr>
        <% if (invoice.due_date) { %>
        <tr>
          <td>Due Date</td>
          <td><%= new Date(invoice.due_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></td>
        </tr>
        <% } %>
        <tr>
          <td>Status</td>
          <td><%= invoice.status.charAt(0).toUpperCase() + invoice.status.slice(1) %></td>
        </tr>
      </table>
    </div>
  </div>

  <!-- Line items -->
  <table class="items">
    <thead>
      <tr>
        <th>Description</th>
        <th>Qty</th>
        <th>Unit Price</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      <% (invoice.items || []).forEach(item => { %>
        <tr>
          <td><%= item.description %></td>
          <td><%= item.quantity %></td>
          <td>$<%= parseFloat(item.unit_price).toFixed(2) %></td>
          <td>$<%= (item.quantity * item.unit_price).toFixed(2) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <!-- Totals -->
  <div class="totals">
    <div class="totals-inner">
      <div class="totals-row">
        <span>Subtotal</span>
        <span>$<%= parseFloat(invoice.subtotal).toFixed(2) %></span>
      </div>
      <% if (parseFloat(invoice.tax_rate) > 0) { %>
        <div class="totals-row">
          <span>Tax (<%= invoice.tax_rate %>%)</span>
          <span>$<%= parseFloat(invoice.tax_amount).toFixed(2) %></span>
        </div>
      <% } %>
      <div class="totals-total">
        <span>Total</span>
        <span>$<%= parseFloat(invoice.total).toFixed(2) %></span>
      </div>
    </div>
  </div>

  <!-- Payment Link (Pro) -->
  <% if (invoice.payment_link_url && user.plan === 'pro') { %>
    <div class="paylink">
      <div class="info">
        <h3>💳 Pay this invoice online</h3>
        <p>Scan the QR code or open the secure payment link below:</p>
        <a href="<%= invoice.payment_link_url %>"><%= invoice.payment_link_url %></a>
      </div>
      <div class="qr" id="invoice-qr" data-url="<%= invoice.payment_link_url %>">
        <noscript><a href="<%= invoice.payment_link_url %>" style="font-size:10px;">Open link</a></noscript>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
    <script>
      (function () {
        var el = document.getElementById('invoice-qr');
        if (!el || typeof QRCode === 'undefined') return;
        QRCode.toString(el.getAttribute('data-url'), { type: 'svg', margin: 1, width: 110 }, function (err, svg) {
          if (!err && svg) el.innerHTML = svg;
        });
      })();
    </script>
  <% } %>

  <!-- Notes -->
  <% if (invoice.notes) { %>
    <div class="notes">
      <div class="label">Notes</div>
      <p><%= invoice.notes %></p>
    </div>
  <% } %>

  <!-- Free-plan attribution footer (passive acquisition; Pro removes it) -->
  <% if (user && user.plan === 'free') { %>
    <div class="free-footer">
      Invoiced with <a href="https://decentinvoice.com/pricing?ref=pdf-footer">DecentInvoice</a> · decentinvoice.com/pricing?ref=pdf-footer
    </div>
  <% } %>
</div>

</body>
</html>

<%- include('partials/head') %>
<%- include('partials/nav') %>

<%
  const statusColors = {
    draft: 'bg-gray-100 text-gray-600',
    sent: 'bg-blue-100 text-blue-700',
    paid: 'bg-green-100 text-green-700',
    overdue: 'bg-red-100 text-red-700'
  };
%>

<div class="max-w-4xl mx-auto px-4 py-10">
  <div class="flex items-center gap-3 mb-6">
    <a href="/invoices" class="text-gray-400 hover:text-gray-600 text-sm">← Invoices</a>
    <span class="text-gray-300">/</span>
    <span class="text-gray-700 font-medium"><%= invoice.invoice_number %></span>
    <span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full <%= statusColors[invoice.status] || 'bg-gray-100 text-gray-600' %>">
      <%= invoice.status.charAt(0).toUpperCase() + invoice.status.slice(1) %>
    </span>
  </div>

  <% if (locals.flash) { %>
    <div class="mb-4 p-3 rounded-lg text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
      <%= flash.message %>
    </div>
  <% } %>

  <!-- Action bar -->
  <div class="flex flex-wrap gap-3 mb-8">
    <% if (invoice.status === 'draft') { %>
      <!-- Draft: the next-action CTA is "Mark as Sent" (Pro users also email the client + create a Stripe Payment Link). Print/Download is demoted to secondary so the lifecycle CTA wins the visual hierarchy. -->
      <form action="/invoices/<%= invoice.id %>/status" method="POST" class="inline">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <input type="hidden" name="status" value="sent">
        <button class="bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-brand-700 transition flex items-center gap-2">
          📤 Mark as Sent
        </button>
      </form>
      <a href="/invoices/<%= invoice.id %>/print" target="_blank"
        class="border border-gray-300 text-gray-700 font-semibold px-5 py-2.5 rounded-lg hover:bg-gray-50 transition">
        📄 View / Download PDF
      </a>
    <% } else { %>
      <a href="/invoices/<%= invoice.id %>/print" target="_blank"
        class="bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-brand-700 transition flex items-center gap-2">
        📄 View / Download PDF
      </a>
    <% } %>
    <a href="/invoices/<%= invoice.id %>/edit"
      class="border border-gray-300 text-gray-700 font-semibold px-5 py-2.5 rounded-lg hover:bg-gray-50 transition">
      ✏️ Edit
    </a>
    <% if (invoice.status !== 'paid') { %>
      <form action="/invoices/<%= invoice.id %>/status" method="POST" class="inline">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
        <input type="hidden" name="status" value="paid">
        <% if (invoice.status === 'sent' || invoice.status === 'overdue') { %>
          <button class="bg-green-600 text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-green-700 transition flex items-center gap-2">
            ✅ Mark as Paid
          </button>
        <% } else { %>
          <button class="border border-green-300 text-green-700 font-semibold px-5 py-2.5 rounded-lg hover:bg-green-50 transition">
            ✅ Mark as Paid
          </button>
        <% } %>
      </form>
    <% } %>
    <form action="/invoices/<%= invoice.id %>/delete" method="POST" class="inline"
      onsubmit="return confirm('Delete this invoice? This cannot be undone.')">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
      <button class="border border-red-200 text-red-600 font-semibold px-5 py-2.5 rounded-lg hover:bg-red-50 transition">
        🗑️ Delete
      </button>
    </form>
  </div>

  <!-- Invoice preview card -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 md:p-12">
    <!-- Header -->
    <div class="flex justify-between items-start mb-10">
      <div>
        <h2 class="text-2xl font-bold text-gray-900"><%= user.business_name || user.name || 'Your Business' %></h2>
        <% if (user.business_address) { %>
          <p class="text-gray-400 text-sm mt-1 whitespace-pre-line"><%= user.business_address %></p>
        <% } %>
        <% if (user.business_email || user.email) { %>
          <p class="text-gray-400 text-sm"><%= user.business_email || user.email %></p>
        <% } %>
        <% if (user.business_phone) { %>
          <p class="text-gray-400 text-sm"><%= user.business_phone %></p>
        <% } %>
      </div>
      <div class="text-right">
        <div class="text-3xl font-extrabold text-brand-600">INVOICE</div>
        <div class="text-gray-500 text-sm mt-1">#<%= invoice.invoice_number %></div>
      </div>
    </div>

    <!-- Invoice meta + Bill To -->
    <div class="grid md:grid-cols-2 gap-8 mb-10">
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Bill To</p>
        <p class="font-semibold text-gray-800"><%= invoice.client_name %></p>
        <% if (invoice.client_email) { %><p class="text-gray-500 text-sm"><%= invoice.client_email %></p><% } %>
        <% if (invoice.client_address) { %><p class="text-gray-500 text-sm whitespace-pre-line"><%= invoice.client_address %></p><% } %>
      </div>
      <div class="text-right">
        <div class="space-y-1 text-sm">
          <div class="flex justify-end gap-8">
            <span class="text-gray-400">Issue Date</span>
            <span class="font-medium text-gray-700"><%= new Date(invoice.issued_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></span>
          </div>
          <% if (invoice.due_date) { %>
          <div class="flex justify-end gap-8">
            <span class="text-gray-400">Due Date</span>
            <span class="font-medium text-gray-700"><%= new Date(invoice.due_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></span>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Line items -->
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b-2 border-gray-200">
          <th class="text-left py-2 text-gray-500 font-semibold">Description</th>
          <th class="text-center py-2 text-gray-500 font-semibold w-20">Qty</th>
          <th class="text-right py-2 text-gray-500 font-semibold w-28">Unit Price</th>
          <th class="text-right py-2 text-gray-500 font-semibold w-28">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% (invoice.items || []).forEach(item => { %>
          <tr class="border-b border-gray-100">
            <td class="py-3 text-gray-700"><%= item.description %></td>
            <td class="py-3 text-center text-gray-500"><%= item.quantity %></td>
            <td class="py-3 text-right text-gray-500">$<%= parseFloat(item.unit_price).toFixed(2) %></td>
            <td class="py-3 text-right font-medium text-gray-800">$<%= (item.quantity * item.unit_price).toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Totals -->
    <div class="flex justify-end mb-8">
      <div class="w-64 space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-500">Subtotal</span>
          <span class="font-medium">$<%= parseFloat(invoice.subtotal).toFixed(2) %></span>
        </div>
        <% if (parseFloat(invoice.tax_rate) > 0) { %>
          <div class="flex justify-between">
            <span class="text-gray-500">Tax (<%= invoice.tax_rate %>%)</span>
            <span class="font-medium">$<%= parseFloat(invoice.tax_amount).toFixed(2) %></span>
          </div>
        <% } %>
        <div class="flex justify-between border-t border-gray-200 pt-2">
          <span class="font-bold text-gray-800">Total</span>
          <span class="font-bold text-xl text-gray-900">$<%= parseFloat(invoice.total).toFixed(2) %></span>
        </div>
      </div>
    </div>

    <!-- Free-plan dead-end recovery (#15). When the invoice has no payment
         link AND the owner is on free, surface a canonical pro-lock card so
         the user can see + click into the paid feature instead of staring
         at a printable PDF and wondering why "Mark as Sent" did nothing.
         Pro/Agency users with payment_link_url fall through to the live UI
         a few lines below; Pro users without a link (e.g. status=draft)
         silently skip this whole section. -->
    <% if (!invoice.payment_link_url && user.plan === 'free') { %>
      <div class="border-t border-gray-100 pt-6 mb-6 space-y-3">
        <%- include('partials/pro-lock', { proLock: {
          feature: 'payment_link',
          icon: '💳',
          headline: 'Add a one-click Stripe pay button to this invoice',
          benefit: 'Pro auto-creates a secure Stripe payment link on every invoice — clients pay by card, ACH, or bank in one click instead of mailing a check.'
        } }) %>
        <%- include('partials/pro-lock', { proLock: {
          feature: 'email_send',
          icon: '✉️',
          headline: 'Email this invoice to the client automatically',
          benefit: 'On Pro, "Mark as Sent" emails the invoice straight to the client with the pay link attached — no copy-paste, no forgotten attachments.'
        } }) %>
      </div>
    <% } %>

    <!-- Public share link (#43). Tokenized /i/<token> URL the freelancer
         can paste into a DM, email, or text so the client views the invoice
         in their browser — no DecentInvoice account required. Open to every
         plan: it's the activation funnel's only in-app way for a free user
         to deliver an invoice. Token is lazy-minted by a fetch() POST to
         /invoices/:id/share on first click; subsequent clicks return the
         cached token. Free users see a tailored sub-line about the missing
         pay button so the Pro upgrade pressure rides every share. -->
    <% const _shareIsPaidOwner = user.plan === 'pro' || user.plan === 'agency'; %>
      <div class="border-t border-gray-100 pt-6 mb-6"
        data-testid="public-share-section"
        data-owner-plan="<%= _shareIsPaidOwner ? 'paid' : 'free' %>"
        x-data="{ url: '', copied: false, loading: false, error: '' }">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Public share link</p>
        <% if (_shareIsPaidOwner) { %>
          <p class="text-gray-500 text-sm mb-3">Send your client a tokenized URL that opens this invoice in their browser — no login required. They see your branding and the pay button.</p>
        <% } else { %>
          <p class="text-gray-500 text-sm mb-3">Send your client a tokenized URL that opens this invoice in their browser — no login required. They see your branding and the totals.</p>
          <div class="bg-brand-50 border border-brand-200 rounded-lg px-4 py-3 mb-3 flex items-start gap-3" data-testid="public-share-free-nudge">
            <span class="text-lg leading-none" aria-hidden="true">💳</span>
            <div class="flex-1 text-sm text-gray-700">
              <p>Your client will see the invoice <strong>without a Pay button</strong> — they'll have to pay you by check, Venmo, or bank transfer.</p>
              <form action="/billing/create-checkout" method="POST" class="inline-flex items-center gap-2 mt-2" data-pro-lock-form>
                <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
                <input type="hidden" name="billing_cycle" value="annual">
                <input type="hidden" name="source" value="share-link-pay-nudge">
                <button type="submit" class="text-brand-700 font-semibold text-sm hover:underline">
                  Add a Stripe Pay button on Pro &rarr;
                </button>
              </form>
            </div>
          </div>
        <% } %>
        <div class="flex items-center gap-2" x-show="!url">
          <button type="button"
            data-testid="public-share-generate"
            @click="loading = true; error = ''; fetch('/invoices/<%= invoice.id %>/share', { method: 'POST', headers: { 'X-CSRF-Token': '<%= locals.csrfToken || '' %>', 'Accept': 'application/json' } }).then(r => r.ok ? r.json() : Promise.reject(new Error('http_' + r.status))).then(data => { url = data.url || ''; loading = false; }).catch(e => { error = 'Could not generate link — try again.'; loading = false; })"
            class="bg-brand-600 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-brand-700 transition disabled:opacity-50"
            :disabled="loading">
            <span x-show="!loading">🔗 Generate share link</span>
            <span x-show="loading">Generating…</span>
          </button>
        </div>
        <div x-show="url" x-cloak class="flex items-center gap-2">
          <input type="text" readonly x-bind:value="url"
            data-testid="public-share-url"
            class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 bg-gray-50 font-mono" />
          <button type="button"
            data-testid="public-share-copy"
            @click="navigator.clipboard.writeText(url).then(() => { copied = true; setTimeout(() => copied = false, 2000); })"
            class="border border-gray-300 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-gray-50 transition text-sm">
            <span x-show="!copied">Copy</span>
            <span x-show="copied" class="text-green-600">Copied!</span>
          </button>
          <a x-bind:href="url" target="_blank" rel="noopener"
            title="Open the client view in a new tab"
            class="border border-gray-300 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-gray-50 transition text-sm whitespace-nowrap">
            Preview ↗
          </a>
        </div>
        <p x-show="error" x-text="error" class="text-red-600 text-xs mt-2"></p>
        <p class="text-gray-400 text-xs mt-2">Anyone with this link can view this invoice — share it only with your client.</p>
      </div>

    <!-- Payment Link (Pro) -->
    <% if (invoice.payment_link_url && user.plan === 'pro') { %>
      <%
        const methods = (typeof paymentMethods !== 'undefined' && Array.isArray(paymentMethods)) ? paymentMethods : ['card'];
        const labelFor = { card: 'card', us_bank_account: 'US bank transfer (ACH)', sepa_debit: 'SEPA Direct Debit', au_becs_debit: 'BECS Direct Debit', bacs_debit: 'BACS Direct Debit', acss_debit: 'Pre-authorised debit', link: 'Stripe Link' };
        const labels = methods.map(m => labelFor[m] || m);
        const methodCopy = labels.length === 1
          ? labels[0]
          : labels.slice(0, -1).join(', ') + ' or ' + labels[labels.length - 1];
        // Share-intent prefill (#92). Native compose targets:
        //   wa.me   → WhatsApp web/app, single `text` query param
        //   sms:    → iOS/Android Messages, `body` after `?` (RFC 5724)
        //   mailto: → Mail.app/Gmail/Outlook, `subject` + `body`
        // Body kept short to fit SMS 160-char window with the URL itself; URL
        // is appended last so even truncated previews preserve the click target.
        const shareGreeting = invoice.client_name ? ('Hi ' + invoice.client_name + ',') : 'Hi,';
        const shareTotal = '$' + parseFloat(invoice.total).toFixed(2);
        const shareBody = shareGreeting + ' here\'s invoice ' + invoice.invoice_number +
          ' for ' + shareTotal + '. You can pay securely here: ' + invoice.payment_link_url;
        const shareSubject = 'Invoice ' + invoice.invoice_number + ' — ' + shareTotal;
        const waHref = 'https://wa.me/?text=' + encodeURIComponent(shareBody);
        const smsHref = 'sms:?&body=' + encodeURIComponent(shareBody);
        // Defence in depth: percent-encode the recipient so a malformed
        // client_email (e.g. one containing `?` or `&`) cannot inject extra
        // mailto: query params. Modern mail clients un-encode `%40` back to
        // `@` correctly; the alternative — passing the raw email — would
        // allow `foo@bar.com?cc=attacker%40evil.com` to silently CC a third
        // party from the user's mail client.
        const mailHref = 'mailto:' + encodeURIComponent(invoice.client_email || '') +
          '?subject=' + encodeURIComponent(shareSubject) +
          '&body=' + encodeURIComponent(shareBody);
      %>
      <div class="border-t border-gray-100 pt-6 mb-6" x-data="{ copied: false }">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Payment Link</p>
        <p class="text-gray-500 text-sm mb-1">Send this secure Stripe link to your client so they can pay in one click.</p>
        <p class="text-gray-400 text-xs mb-3">Clients can pay via <%= methodCopy %>.</p>
        <div class="flex items-center gap-2">
          <input type="text" readonly value="<%= invoice.payment_link_url %>"
            data-pay-link-url="<%= invoice.payment_link_url %>"
            class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 bg-gray-50 font-mono" />
          <button type="button"
            @click="navigator.clipboard.writeText($root.querySelector('[data-pay-link-url]').dataset.payLinkUrl).then(() => { copied = true; setTimeout(() => copied = false, 2000); })"
            class="border border-gray-300 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-gray-50 transition text-sm">
            <span x-show="!copied">Copy</span>
            <span x-show="copied" class="text-green-600">Copied!</span>
          </button>
          <a href="<%= invoice.payment_link_url %>" target="_blank" rel="noopener"
            title="Open the Stripe payment page your client will see"
            class="border border-gray-300 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-gray-50 transition text-sm whitespace-nowrap">
            Preview ↗
          </a>
        </div>
        <p class="text-gray-400 text-xs mt-2">Preview opens the page your client sees.</p>

        <!-- Share to client (#92) — WhatsApp / SMS / Email open the user's
             native compose window with the pay link prefilled. No data leaves
             the browser; clicking just calls the OS's URL handler. -->
        <div class="mt-4 pt-4 border-t border-gray-100">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Send to client</p>
          <div class="flex flex-wrap gap-2">
            <a href="<%= waHref %>" target="_blank" rel="noopener"
              data-share="whatsapp"
              title="Open WhatsApp with a prefilled message"
              class="inline-flex items-center gap-2 border border-gray-300 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-green-50 hover:border-green-300 transition text-sm">
              <span aria-hidden="true">💬</span>
              <span>WhatsApp</span>
            </a>
            <a href="<%= smsHref %>"
              data-share="sms"
              title="Open Messages with a prefilled SMS"
              class="inline-flex items-center gap-2 border border-gray-300 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-blue-50 hover:border-blue-300 transition text-sm">
              <span aria-hidden="true">📱</span>
              <span>SMS</span>
            </a>
            <a href="<%= mailHref %>"
              data-share="email"
              title="Open your email client with a prefilled message"
              class="inline-flex items-center gap-2 border border-gray-300 text-gray-700 font-semibold px-4 py-2 rounded-lg hover:bg-indigo-50 hover:border-indigo-300 transition text-sm">
              <span aria-hidden="true">✉️</span>
              <span>Email</span>
            </a>
          </div>
          <p class="text-gray-400 text-xs mt-2">Each button opens your native app with the message prefilled — review and hit send.</p>
        </div>
      </div>
    <% } %>

    <!-- Notes -->
    <% if (invoice.notes) { %>
      <div class="border-t border-gray-100 pt-6">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Notes</p>
        <p class="text-gray-500 text-sm whitespace-pre-line"><%= invoice.notes %></p>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

</body>
</html>

<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-gray-900">Set a new password</h1>
      <% if (!locals.invalid && locals.email) { %>
        <p class="text-gray-500 mt-1 text-sm">For <strong><%= locals.email %></strong></p>
      <% } else if (!locals.invalid) { %>
        <p class="text-gray-500 mt-1 text-sm">Enter a new password to finish signing in.</p>
      <% } %>
    </div>

    <% if (locals.flash) { %>
      <div class="mb-4 p-3 rounded-lg text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
        <%= flash.message %>
      </div>
    <% } %>

    <% if (locals.invalid) { %>
      <div data-testid="reset-invalid" class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 text-center">
        <div class="text-3xl mb-2">⏱</div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2">This link is no longer valid</h2>
        <p class="text-sm text-gray-600">
          Reset links expire after 60 minutes and can only be used once. Request a fresh one and we'll send it right away.
        </p>
        <a href="/auth/forgot" class="mt-5 inline-block bg-brand-600 text-white font-semibold py-2.5 px-5 rounded-lg hover:bg-brand-700 transition">
          Request a new link &rarr;
        </a>
      </div>
    <% } else { %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <form action="/auth/reset/<%= locals.token %>" method="POST" class="space-y-4">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">New password <span class="text-gray-400 font-normal">(8+ characters)</span></label>
            <input type="password" name="password" required autocomplete="new-password" minlength="8"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          </div>
          <button type="submit" class="w-full bg-brand-600 text-white font-semibold py-2.5 rounded-lg hover:bg-brand-700 transition">
            Set new password &rarr;
          </button>
        </form>
      </div>
    <% } %>

    <p class="text-center text-sm text-gray-500 mt-6">
      Remembered it? <a href="/auth/login" class="text-brand-600 font-medium hover:underline">Back to log in</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>

</body>
</html>

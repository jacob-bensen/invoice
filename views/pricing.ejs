<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="text-center mb-14">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Upgrade to Pro</h1>
    <p class="text-gray-500 text-lg">Unlimited invoices for just $12/month. Cancel anytime.</p>
  </div>

  <% if (locals.flash) { %>
    <div class="mb-8 p-4 rounded-xl text-sm max-w-xl mx-auto <%= flash.type === 'error' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
      <%= flash.message %>
    </div>
  <% } %>

  <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
    <!-- Free -->
    <div class="bg-white rounded-2xl border border-gray-200 p-8">
      <h3 class="text-xl font-bold mb-1">Free</h3>
      <div class="text-4xl font-extrabold text-gray-900 mb-1">$0</div>
      <p class="text-gray-400 text-sm mb-6">Your current plan</p>
      <ul class="space-y-3 text-sm text-gray-600">
        <li class="flex items-center gap-2"><span class="text-green-500">✓</span> 3 invoices total</li>
        <li class="flex items-center gap-2"><span class="text-green-500">✓</span> PDF download</li>
        <li class="flex items-center gap-2"><span class="text-green-500">✓</span> Payment tracking</li>
        <li class="flex items-center gap-2 text-gray-300"><span>×</span> Unlimited invoices</li>
        <li class="flex items-center gap-2 text-gray-300"><span>×</span> Business branding</li>
        <li class="flex items-center gap-2 text-gray-300"><span>×</span> Priority support</li>
      </ul>
    </div>

    <!-- Pro -->
    <div class="bg-brand-600 rounded-2xl p-8 text-white shadow-lg">
      <h3 class="text-xl font-bold mb-1">Pro</h3>
      <div class="text-4xl font-extrabold mb-1">$12<span class="text-xl font-normal text-brand-200">/mo</span></div>
      <p class="text-brand-200 text-sm mb-6">Billed monthly · Cancel anytime</p>
      <ul class="space-y-3 text-sm text-brand-100 mb-8">
        <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> <strong class="text-white">Unlimited</strong> invoices</li>
        <li class="flex items-center gap-2"><span class="text-white">✓</span> PDF download</li>
        <li class="flex items-center gap-2"><span class="text-white">✓</span> Payment tracking</li>
        <li class="flex items-center gap-2"><span class="text-white">✓</span> Business branding</li>
        <li class="flex items-center gap-2"><span class="text-white">✓</span> Priority support</li>
        <li class="flex items-center gap-2"><span class="text-white">✓</span> All future features</li>
      </ul>
      <% if (user && user.plan === 'pro') { %>
        <div class="bg-white/20 text-center text-sm font-semibold py-3 rounded-xl">
          ✓ You're already on Pro!
        </div>
        <form action="/billing/portal" method="POST" class="mt-3">
          <button class="w-full text-center text-white/80 text-sm hover:text-white py-2 underline underline-offset-2">
            Manage subscription
          </button>
        </form>
      <% } else { %>
        <form action="/billing/create-checkout" method="POST">
          <button type="submit" class="w-full bg-white text-brand-700 font-bold py-3 rounded-xl hover:bg-brand-50 transition text-center">
            Upgrade now →
          </button>
        </form>
        <p class="text-xs text-brand-200 text-center mt-3">Secure checkout via Stripe</p>
      <% } %>
    </div>
  </div>

  <p class="text-center text-gray-400 text-sm mt-8">
    Questions? Email us anytime. We're happy to help.
  </p>
</div>

</body>
</html>

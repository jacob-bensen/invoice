<%- include('partials/head') %>
<%- include('partials/nav') %>

<%
  const recentClientsList = (locals.recentClients && Array.isArray(recentClients)) ? recentClients : [];
  const initialClient = {
    name: invoice ? (invoice.client_name || '') : '',
    email: invoice && invoice.client_email ? invoice.client_email : '',
    address: invoice && invoice.client_address ? invoice.client_address : ''
  };
%>
<div class="max-w-4xl mx-auto px-4 py-10" x-data="invoiceEditor(<%= JSON.stringify(invoice ? invoice.items : []) %>, <%= JSON.stringify(recentClientsList) %>, <%= JSON.stringify(initialClient) %>)">
  <div class="flex items-center gap-3 mb-8">
    <a href="/invoices" class="text-gray-400 hover:text-gray-600 text-sm">← Invoices</a>
    <span class="text-gray-300">/</span>
    <h1 class="text-2xl font-bold text-gray-900"><%= invoice ? 'Edit Invoice' : 'New Invoice' %></h1>
  </div>

  <% if (locals.flash) { %>
    <div class="mb-6 p-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200">
      <%= flash.message %>
    </div>
  <% } %>

  <form action="/invoices/<%= invoice ? invoice.id + '/edit' : 'new' %>" method="POST">
    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">
    <div class="grid md:grid-cols-2 gap-6">

      <!-- Invoice Details -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <h2 class="font-semibold text-gray-700 mb-4 text-sm uppercase tracking-wide">Invoice Details</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Invoice Number</label>
            <input type="text" name="invoice_number" required
              value="<%= invoice ? invoice.invoice_number : invoiceNumber %>"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Issue Date</label>
              <input type="date" name="issued_date"
                value="<%= invoice ? invoice.issued_date.toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Due Date <span class="text-gray-400 font-normal text-xs">(defaults to 30 days)</span></label>
              <input type="date" name="due_date"
                value="<%= invoice && invoice.due_date ? invoice.due_date.toISOString().split('T')[0] : new Date(Date.now() + 30*86400000).toISOString().split('T')[0] %>"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            </div>
          </div>
          <% if (invoice) { %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select name="status" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
              <% ['draft','sent','paid','overdue'].forEach(s => { %>
                <option value="<%= s %>" <%= invoice.status === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
              <% }) %>
            </select>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Client Info -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <h2 class="font-semibold text-gray-700 mb-4 text-sm uppercase tracking-wide">Bill To</h2>
        <div class="space-y-4">
          <% if (recentClientsList.length > 0) { %>
          <div data-recent-clients>
            <label for="recent-client-picker" class="block text-sm font-medium text-gray-700 mb-1">Recent clients</label>
            <select id="recent-client-picker" x-model="picked" @change="fillFromRecent()"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="">Quick-pick from recent…</option>
              <% recentClientsList.forEach(function(c, idx) { %>
                <option value="<%= idx %>"><%= c.client_name %><%= c.client_email ? ' · ' + c.client_email : '' %></option>
              <% }) %>
            </select>
            <p class="text-xs text-gray-400 mt-1">Selecting fills the fields below — you can still edit them.</p>
          </div>
          <% } %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Client Name <span class="text-red-400">*</span></label>
            <input type="text" name="client_name" required x-model="clientName"
              placeholder="Acme Corp"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Client Email</label>
            <input type="email" name="client_email" x-model="clientEmail"
              placeholder="client@example.com"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Client Address</label>
            <textarea name="client_address" rows="3" placeholder="123 Main St&#10;City, State 12345" x-model="clientAddress"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- Line Items -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mt-6">
      <h2 class="font-semibold text-gray-700 mb-4 text-sm uppercase tracking-wide">Line Items</h2>

      <!-- Header row -->
      <div class="grid grid-cols-12 gap-3 mb-2 text-xs font-semibold text-gray-500 uppercase tracking-wide">
        <div class="col-span-6">Description</div>
        <div class="col-span-2 text-center">Qty</div>
        <div class="col-span-2 text-right">Unit Price</div>
        <div class="col-span-2 text-right">Amount</div>
      </div>

      <template x-for="(item, i) in items" :key="i">
        <div class="grid grid-cols-12 gap-3 mb-2 items-center">
          <div class="col-span-6">
            <input type="text" x-model="item.description" placeholder="Service or product"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" required>
          </div>
          <div class="col-span-2">
            <input type="number" x-model.number="item.quantity" min="0" step="any"
              @input="recalculate()"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm text-center focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div class="col-span-2">
            <input type="number" x-model.number="item.unit_price" min="0" step="0.01" placeholder="0.00"
              @input="recalculate()"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm text-right focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div class="col-span-1 text-right text-sm font-medium text-gray-700" x-text="'$' + (item.quantity * item.unit_price).toFixed(2)"></div>
          <div class="col-span-1 text-right">
            <button type="button" @click="removeItem(i)" class="text-red-400 hover:text-red-600 text-lg leading-none" x-show="items.length > 1">×</button>
          </div>
        </div>
      </template>

      <button type="button" @click="addItem()"
        class="mt-3 text-brand-600 text-sm font-medium hover:text-brand-700 flex items-center gap-1">
        + Add line item
      </button>

      <!-- Totals -->
      <div class="mt-6 border-t border-gray-100 pt-4">
        <div class="flex flex-col items-end gap-2 text-sm">
          <div class="flex justify-between w-64">
            <span class="text-gray-500">Subtotal</span>
            <span class="font-medium" x-text="'$' + subtotal.toFixed(2)"></span>
          </div>
          <div class="flex items-center justify-between w-64">
            <div class="flex items-center gap-2">
              <span class="text-gray-500">Tax</span>
              <input type="number" x-model.number="taxRate" min="0" max="100" step="0.1"
                @input="recalculate()" placeholder="0"
                class="w-14 border border-gray-300 rounded px-2 py-1 text-xs text-center focus:outline-none focus:ring-2 focus:ring-brand-500">
              <span class="text-gray-400 text-xs">%</span>
            </div>
            <span class="font-medium" x-text="'$' + taxAmount.toFixed(2)"></span>
          </div>
          <div class="flex justify-between w-64 border-t border-gray-200 pt-2">
            <span class="font-semibold text-gray-700">Total</span>
            <span class="font-bold text-lg text-gray-900" x-text="'$' + total.toFixed(2)"></span>
          </div>
        </div>
      </div>

      <!-- Hidden fields for form submission -->
      <input type="hidden" name="items" :value="JSON.stringify(items)">
      <input type="hidden" name="subtotal" :value="subtotal.toFixed(2)">
      <input type="hidden" name="tax_rate" :value="taxRate">
      <input type="hidden" name="tax_amount" :value="taxAmount.toFixed(2)">
      <input type="hidden" name="total" :value="total.toFixed(2)">
    </div>

    <!-- Notes -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mt-6">
      <h2 class="font-semibold text-gray-700 mb-4 text-sm uppercase tracking-wide">Notes</h2>
      <textarea name="notes" rows="3" placeholder="Payment terms, bank details, thank you note..."
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"><%= invoice ? (invoice.notes || '') : '' %></textarea>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between mt-6">
      <a href="/invoices" class="text-gray-500 hover:text-gray-700 text-sm">Cancel</a>
      <button type="submit" class="bg-brand-600 text-white font-semibold px-8 py-3 rounded-xl hover:bg-brand-700 transition">
        <% if (invoice) { %>Save changes<% } else { %>Create invoice &rarr;<% } %>
      </button>
    </div>
  </form>
</div>

<script>
function invoiceEditor(initialItems, initialRecentClients, initialClient) {
  const c = initialClient && typeof initialClient === 'object' ? initialClient : {};
  return {
    items: initialItems && initialItems.length > 0
      ? initialItems.map(i => ({ description: i.description, quantity: Number(i.quantity), unit_price: Number(i.unit_price) }))
      : [{ description: '', quantity: 1, unit_price: 0 }],
    taxRate: <%= invoice ? Number(invoice.tax_rate) : 0 %>,
    subtotal: 0,
    taxAmount: 0,
    total: 0,
    recentClients: Array.isArray(initialRecentClients) ? initialRecentClients : [],
    picked: '',
    clientName: typeof c.name === 'string' ? c.name : '',
    clientEmail: typeof c.email === 'string' ? c.email : '',
    clientAddress: typeof c.address === 'string' ? c.address : '',

    init() { this.recalculate(); },

    fillFromRecent() {
      const idx = parseInt(this.picked, 10);
      if (Number.isNaN(idx) || idx < 0 || idx >= this.recentClients.length) return;
      const c = this.recentClients[idx];
      if (!c) return;
      this.clientName = c.client_name || '';
      this.clientEmail = c.client_email || '';
      this.clientAddress = c.client_address || '';
    },

    addItem() {
      this.items.push({ description: '', quantity: 1, unit_price: 0 });
    },
    removeItem(i) {
      this.items.splice(i, 1);
      this.recalculate();
    },
    recalculate() {
      this.subtotal = this.items.reduce((s, i) => s + (Number(i.quantity) * Number(i.unit_price)), 0);
      this.taxAmount = this.subtotal * (this.taxRate / 100);
      this.total = this.subtotal + this.taxAmount;
    }
  };
}
</script>

<%- include('partials/upgrade-modal') %>

</body>
</html>

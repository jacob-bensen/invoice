<%- include('partials/head') %>
<%- include('partials/nav') %>

<!-- Hero -->
<section class="bg-gradient-to-br from-brand-600 to-brand-800 text-white py-24 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-block bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full mb-6">
      Free to start — no credit card required
    </div>
    <h1 class="text-5xl font-extrabold mb-6 leading-tight">
      Professional invoices.<br>In under a minute.
    </h1>
    <p class="text-xl text-brand-100 mb-10 max-w-2xl mx-auto">
      Create, send, and track invoices effortlessly. Built for freelancers and small businesses who just want to get paid.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/auth/register" class="bg-white text-brand-700 font-bold px-8 py-4 rounded-xl hover:bg-brand-50 transition text-lg shadow-lg">
        Create your first invoice →
      </a>
      <a href="#pricing" class="border border-white/50 text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">
        See pricing
      </a>
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-20 px-4 bg-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-14">Everything you need to get paid</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center p-6">
        <div class="text-4xl mb-4">📄</div>
        <h3 class="text-lg font-semibold mb-2">Professional invoices</h3>
        <p class="text-gray-500">Clean, branded invoices your clients will trust. Add line items, taxes, notes, and due dates.</p>
      </div>
      <div class="text-center p-6">
        <div class="text-4xl mb-4">🖨️</div>
        <h3 class="text-lg font-semibold mb-2">Instant PDF download</h3>
        <p class="text-gray-500">One click to print or download your invoice as a PDF — ready to email or attach to any project.</p>
      </div>
      <div class="text-center p-6">
        <div class="text-4xl mb-4">📊</div>
        <h3 class="text-lg font-semibold mb-2">Track payments</h3>
        <p class="text-gray-500">Mark invoices as sent or paid. Always know what's outstanding and what's been collected.</p>
      </div>
      <div class="text-center p-6">
        <div class="text-4xl mb-4">⚡</div>
        <h3 class="text-lg font-semibold mb-2">Takes 60 seconds</h3>
        <p class="text-gray-500">No complex setup. Fill in the client details, add your services, download. Done.</p>
      </div>
      <div class="text-center p-6">
        <div class="text-4xl mb-4">🔒</div>
        <h3 class="text-lg font-semibold mb-2">Secure & private</h3>
        <p class="text-gray-500">Your invoices are private to your account. Encrypted passwords. No data selling — ever.</p>
      </div>
      <div class="text-center p-6">
        <div class="text-4xl mb-4">💼</div>
        <h3 class="text-lg font-semibold mb-2">Your business branding</h3>
        <p class="text-gray-500">Add your business name, address, and contact info. Every invoice represents your brand.</p>
      </div>
    </div>
  </div>
</section>

<!-- Pricing -->
<section id="pricing" class="py-20 px-4 bg-gray-50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-gray-900 mb-4">Simple, honest pricing</h2>
    <p class="text-center text-gray-500 mb-14">Start free. Upgrade when you're ready.</p>
    <div class="grid md:grid-cols-2 gap-8 max-w-2xl mx-auto">
      <!-- Free -->
      <div class="bg-white rounded-2xl border border-gray-200 p-8 shadow-sm">
        <h3 class="text-xl font-bold mb-1">Free</h3>
        <div class="text-4xl font-extrabold text-gray-900 mb-1">$0</div>
        <p class="text-gray-500 text-sm mb-6">Forever free</p>
        <ul class="space-y-3 mb-8 text-sm text-gray-600">
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> Up to 3 invoices</li>
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> PDF download</li>
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> All invoice fields</li>
          <li class="flex items-center gap-2"><span class="text-green-500">✓</span> Payment tracking</li>
          <li class="flex items-center gap-2 text-gray-300"><span>×</span> Stripe payment links</li>
          <li class="flex items-center gap-2 text-gray-300"><span>×</span> Email invoices to clients</li>
          <li class="flex items-center gap-2 text-gray-300"><span>×</span> Auto reminder emails</li>
        </ul>
        <a href="/auth/register" class="block text-center border border-brand-600 text-brand-600 font-semibold py-3 rounded-xl hover:bg-brand-50 transition">
          Get started free
        </a>
      </div>
      <!-- Pro -->
      <div class="bg-brand-600 rounded-2xl p-8 shadow-lg text-white relative overflow-hidden">
        <div class="absolute top-4 right-4 bg-white/20 text-xs font-bold px-2 py-1 rounded-full">MOST POPULAR</div>
        <h3 class="text-xl font-bold mb-1">Pro</h3>
        <div class="text-4xl font-extrabold mb-1">$12<span class="text-xl font-normal text-brand-200">/mo</span></div>
        <p class="text-brand-200 text-sm mb-1">Or $99/year — <span class="font-semibold text-emerald-200">save $45/year</span></p>
        <p class="text-brand-200 text-sm mb-6">Cancel anytime</p>
        <ul class="space-y-3 mb-8 text-sm text-brand-100">
          <li class="flex items-center gap-2"><span class="text-white">✓</span> <strong class="text-white">Unlimited</strong> invoices</li>
          <li class="flex items-center gap-2"><span class="text-white">✓</span> Stripe payment links — clients pay in one click</li>
          <li class="flex items-center gap-2"><span class="text-white">✓</span> Email invoices directly to clients</li>
          <li class="flex items-center gap-2"><span class="text-white">✓</span> Automated payment reminders</li>
          <li class="flex items-center gap-2"><span class="text-white">✓</span> Business branding</li>
          <li class="flex items-center gap-2"><span class="text-white">✓</span> Priority support</li>
        </ul>
        <a href="/auth/register" class="block text-center bg-white text-brand-700 font-bold py-3 rounded-xl hover:bg-brand-50 transition">
          Start 7-day free trial &rarr;
        </a>
        <p class="text-center text-xs text-brand-200 mt-3">No credit card required</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 px-4 bg-brand-600 text-white text-center">
  <h2 class="text-3xl font-bold mb-4">Ready to get paid faster?</h2>
  <p class="text-brand-200 mb-8 text-lg">Sign up free in under a minute. No credit card needed to start.</p>
  <a href="/auth/register" class="bg-white text-brand-700 font-bold px-10 py-4 rounded-xl hover:bg-brand-50 transition text-lg inline-block shadow-lg">
    Create free account →
  </a>
  <p class="text-brand-200 text-sm mt-4">Pro plan: 7-day free trial · cancel anytime · no credit card required</p>
</section>

<footer class="bg-gray-900 text-gray-400 text-center py-10 text-sm">
  <nav aria-label="Footer" class="mb-3">
    <a href="/" class="hover:text-white px-3">Home</a>
    <span class="text-gray-700">·</span>
    <a href="#pricing" class="hover:text-white px-3">Pricing</a>
    <span class="text-gray-700">·</span>
    <a href="/auth/login" class="hover:text-white px-3">Log in</a>
    <span class="text-gray-700">·</span>
    <a href="/auth/register" class="hover:text-white px-3">Sign up free</a>
  </nav>
  <p class="text-gray-500">&copy; <%= new Date().getFullYear() %> QuickInvoice. Built for freelancers.</p>
</footer>
</body>
</html>
